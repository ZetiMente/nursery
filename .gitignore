# Node / editors
node_modules/
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Build
dist/
build/
*.egg-info/
.ruff_cache/
.pytest_cache/
uv.lock-* # stray lock copies only; uv.lock itself IS committed

# =============================================================================
# SECRETS - NEVER COMMIT
# =============================================================================
# If you add a new secret file type, ADD IT HERE FIRST.

# Environment files
.env
.env.*
!.env.example

# Credentials / tokens (any name, any depth)
*secret*.json
*secrets*.json
*token*.json
*credentials*.json
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt

# Common secret directories
secrets/
credentials/
.secrets/
keys/

# OAuth / cloud
*oauth*.json
*_service_account*.json
*-service-account*.json
.gcp/
.aws/

# SSH
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
known_hosts

# API keys in misc formats
api_key*
apikey*
*.apikey

# Agent workspaces — contain memory / personal context
workspaces/
*_workspace/
workspace-*/
