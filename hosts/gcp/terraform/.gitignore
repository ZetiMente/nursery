# Terraform state + local artifacts
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl.bak

# Local variable files — typically contain personal values (project ID,
# IP, etc.). Committed values would force everyone to use the same.
terraform.tfvars
*.auto.tfvars

# Plan outputs
*.tfplan
plan.out

# Backend partial-config — bucket name is per-project, generated by
# bootstrap/. Each user/project gets their own; do not commit.
backend.hcl

# Crash log
crash.log

# Application default credentials should never land here
adc.json
application_default_credentials.json
