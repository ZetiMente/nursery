# Terraform state + local artifacts
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl.bak

# Local variable files — typically contain personal values (key pair name,
# IP, bid prices). Committed values would force everyone to use the same.
# Commit terraform.tfvars.example instead if you want to share defaults.
terraform.tfvars
*.auto.tfvars

# Plan outputs
*.tfplan
plan.out

# Backend partial-config — bucket name is per-account, generated by
# bootstrap/. Each user/account gets their own; do not commit.
backend.hcl

# Crash log
crash.log
